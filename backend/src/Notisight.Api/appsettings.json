{
  "ConnectionStrings": {
    "DefaultConnection": "sql_server_connection_string"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.example.com"
    ]
  },
  "Database": {
    "SkipMigrations": false,
    "ApplyMigrationsOnStartup": false
  },
  "Jwt": {
    "Issuer": "jwt_issuer",
    "Audience": "jwt_audience",
    "SigningKey": "jwt_signing_key",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 14
  },
  "Gemini": {
    "ApiKey": "gemini_api_key",
    "ChatModel": "gemini_chat_model",
    "EmbeddingModel": "gemini_embedding_model"
  },
  "Deepgram": {
    "ApiKey": "deepgram_api_key",
    "Endpoint": "deepgram_endpoint_url",
    "Model": "deepgram_model",
    "Language": "transcription_language",
    "SmartFormat": true
  },
  "OpenAi": {
    "ApiKey": "openai_api_key",
    "BaseUrl": "openai_base_url",
    "ChatModel": "openai_chat_model"
  },
  "Qdrant": {
    "Url": "qdrant_url",
    "Endpoint": "qdrant_endpoint",
    "ApiKey": "qdrant_api_key",
    "CollectionName": "qdrant_collection_name",
    "VectorSize": 768
  },
  "CloudflareR2": {
    "BucketName": "cloudflare_r2_bucket_name",
    "AccessKey": "cloudflare_r2_access_key",
    "SecretKey": "cloudflare_r2_secret_key",
    "EndpointUrl": "cloudflare_r2_endpoint_url",
    "PublicUrlPrefix": "cloudflare_r2_public_url_prefix"
  },
  "Rag": {
    "ChunkTokenTarget": 350,
    "ChunkOverlapPercent": 15,
    "TopK": 8,
    "MinVectorScore": 0.7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
